---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/TuiLayout.astro';
import type { DocsSection } from '../lib/docs-nav';

export async function getStaticPaths() {
  const collections = ['gettingStarted', 'concepts'] as const;
  const sectionMap: Record<(typeof collections)[number], DocsSection> = {
    gettingStarted: 'getting-started',
    concepts: 'concepts',
  };
  const toRoute = (section: DocsSection, id: string) => (id === 'index' ? section : `${section}/${id}`);
  const paths = [];

  for (const collection of collections) {
    const entries = await getCollection(collection);
    const section = sectionMap[collection];

    for (const entry of entries) {
      paths.push({
        params: { slug: toRoute(section, entry.id) },
        props: { entry, section },
      });
    }
  }

  return paths;
}

const { entry, section } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={entry.data.title} section={section}>
  <Content />
</Layout>
