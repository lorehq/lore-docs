---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/TuiLayout.astro';

const howTo = await getCollection('how-to');
---

<Layout title="How-to Guides">
  <div class="flex flex-col gap-0.5">
    {howTo.filter(e => !e.id.includes('/')).map(entry => (
      <a href={`/how-to/${entry.id}`} class="group flex items-center gap-3 px-2 py-1 hover:bg-tui-selected-bg hover:text-white transition-none">
        <span class="text-tui-border-inactive group-hover:text-white font-mono opacity-50">#</span>
        <div class="flex-1 min-w-0">
          <span class="text-tui-accent group-hover:text-white font-bold text-xs uppercase tracking-wider">{entry.data.title || entry.id}</span>
          {entry.data.description && <span class="ml-4 text-[10px] text-tui-fg opacity-40 group-hover:opacity-100 group-hover:text-white italic">{entry.data.description}</span>}
        </div>
      </a>
    ))}
  </div>
</Layout>
