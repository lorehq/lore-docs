---
import '../styles/global.css';
import type { DocsSection } from '../lib/docs-nav';
import TopNav from '../components/TopNav.astro';
import SidebarNav from '../components/SidebarNav.astro';
import ThemeSwitcher from '../components/ThemeSwitcher';
import ImageLightbox from '../components/ImageLightbox';

interface Props {
  title: string;
  section?: DocsSection;
}

const { title, section = 'home' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="h-full w-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Lore</title>
    
    <!-- Universal Font: DejaVu Sans Mono -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/dejavu-sans-mono/index.css">

    <script is:inline>
      // Blocking script to prevent theme flashing
      (function() {
        const savedTheme = localStorage.getItem('tui-theme') || 'mocha';
        document.documentElement.setAttribute('data-theme', savedTheme);
      })();
    </script>
  </head>
  <body class="site-body bg-tui-bg text-tui-fg">
    <TopNav section={section} />
    <div class="docs-shell">
      <SidebarNav section={section} currentPath={currentPath} />
      <main class="docs-main">
        <article class="docs-article prose text-tui-fg max-w-none">
          <slot />
        </article>
      </main>
    </div>

    <footer class="site-footer">
      <ThemeSwitcher client:idle />
      <div class="site-footer-version">Lore <span class="text-tui-accent">0.24.5-BLUE</span></div>
    </footer>
    <ImageLightbox client:idle />

    <script is:inline>
      const article = document.querySelector('article');

      article?.querySelectorAll('pre').forEach((pre) => {
        const code = pre.querySelector('code');
        if (!code) return;

        pre.classList.add('copy-ready');

        const button = document.createElement('button');
        button.className = 'code-copy-btn';
        button.type = 'button';
        button.textContent = 'Copy';
        button.setAttribute('aria-label', 'Copy code to clipboard');

        button.addEventListener('click', async () => {
          const text = code.innerText;
          try {
            await navigator.clipboard.writeText(text);
            button.textContent = 'Copied';
            button.classList.add('copied');
            window.setTimeout(() => {
              button.textContent = 'Copy';
              button.classList.remove('copied');
            }, 1600);
          } catch {
            button.textContent = 'Error';
            window.setTimeout(() => {
              button.textContent = 'Copy';
            }, 1600);
          }
        });

        pre.appendChild(button);
      });
    </script>
  </body>
</html>
