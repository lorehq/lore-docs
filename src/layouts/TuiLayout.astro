---
import '../styles/global.css';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
}

const { title } = Astro.props;

const explanation = await getCollection('explanation');
const reference = await getCollection('reference');

const topReference = reference.filter(e => !e.id.includes('/'));
---

<!doctype html>
<html lang="en" class="h-full w-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Lore</title>
    
    <!-- Monaspace Font Import via Fontsource -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/monaspace-neon/index.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/monaspace-argon/index.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/monaspace-xenon/index.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/monaspace-radon/index.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/monaspace-krypton/index.css">

    <script is:inline>
      // Blocking script to prevent theme/font flashing
      (function() {
        const savedTheme = localStorage.getItem('tui-theme') || 'solarized';
        document.documentElement.setAttribute('data-theme', savedTheme);
        
        const savedFont = localStorage.getItem('tui-font') || 'neon';
        document.documentElement.setAttribute('data-font', savedFont);
      })();
    </script>
    <style is:global>
      /* Styling for svg-pan-zoom controls to match TUI theme */
      .svg-pan-zoom-control {
        fill: var(--tui-border-inactive) !important;
        fill-opacity: 0.8 !important;
      }
      .svg-pan-zoom-control:hover {
        fill: var(--tui-border-active) !important;
        fill-opacity: 1 !important;
      }
      .svg-pan-zoom-control-background {
        fill: var(--tui-bg-hl) !important;
        fill-opacity: 0.5 !important;
      }

      .mermaid {
        height: 600px;
        min-height: 400px;
        overflow: hidden;
        cursor: grab;
        margin-top: 1.5rem;
        margin-bottom: 1.5rem;
        display: flex;
        justify-content: center;
        background-color: var(--tui-bg);
        padding: 1rem;
        border-width: 1px;
        border-style: solid;
        border-color: var(--tui-border-inactive);
        border-radius: 0.125rem;
      }
      .mermaid:active {
        cursor: grabbing;
      }
      .mermaid svg {
        height: 100% !important;
        width: 100% !important;
      }

      .scrollbar-hide::-webkit-scrollbar {
        display: none;
      }
      .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }

      .tui-btn {
        padding-left: 0.25rem;
        padding-right: 0.25rem;
        border: 1px solid transparent;
        cursor: pointer;
        transition: all 0.2s;
        font-size: 10px;
        background: transparent;
        color: inherit;
      }
      .tui-btn:hover {
        border-color: var(--tui-border-active);
        color: var(--tui-border-active);
      }
      .tui-btn.active {
        color: var(--tui-border-active);
        border-color: var(--tui-border-active);
        background-color: var(--tui-bg-hl);
      }
    </style>
  </head>
  <body class="h-screen w-screen p-2 box-border flex flex-col gap-2 overflow-hidden bg-tui-bg text-tui-fg select-none">
    <div class="flex flex-1 gap-2 overflow-hidden">
      <!-- Single Navigation Panel -->
      <aside class="relative border border-tui-border-inactive w-80 flex flex-col mt-3">
        <span class="absolute -top-2.5 left-2 bg-tui-bg px-1 text-[10px] text-tui-border-inactive">─[1]─Navigation─</span>

        <nav class="flex-1 overflow-y-auto p-2 pt-4 flex flex-col gap-4 scrollbar-hide text-xs">
          <!-- Home -->
          <div>
            <a href="/" class="py-0.5 px-2 hover:bg-tui-selected-bg hover:text-white block transition-none">Home</a>
          </div>

          <!-- Architecture Section -->
          <div>
            <div class="opacity-70 text-[11px] px-2 uppercase mb-1 font-bold text-tui-accent">Architecture</div>
            {explanation.filter(e => !e.id.includes('/')).map(entry => (
              <a href={`/explanation/${entry.id}`} class="py-0.5 px-2 hover:bg-tui-selected-bg hover:text-white block truncate transition-none">{entry.data.title}</a>
            ))}
          </div>

          <!-- Reference Section -->
          <div class="mb-4">
            <div class="opacity-70 text-[11px] px-2 uppercase mb-1 font-bold text-tui-accent">Reference</div>
            {topReference.map(entry => (
              <a href={`/reference/${entry.id}`} class="py-0.5 px-2 hover:bg-tui-selected-bg hover:text-white block truncate transition-none">{entry.data.title}</a>
            ))}
          </div>
        </nav>
      </aside>

      <!-- Main Content (Active) -->
      <main class="relative border border-tui-border-active flex-1 flex flex-col mt-3">
        <span class="absolute -top-2.5 left-4 bg-tui-bg px-1 text-[10px] text-tui-border-active">─{title}─</span>

        <article class="flex-1 overflow-y-auto p-8 pt-10 prose text-tui-fg max-w-none scrollbar-hide">
          <slot />
        </article>
      </main>
    </div>

    <!-- Bottom Status Bar -->
    <footer class="h-6 flex items-center px-2 text-[10px] text-tui-border-inactive border-t border-tui-bg-hl justify-between">
      <div class="flex gap-4 items-center">
        <span>PgUp/PgDn: scroll</span>
        <div class="h-3 w-px bg-tui-bg-hl mx-1"></div>
        <div class="flex gap-2 items-center">
          <span class="opacity-50">THEME:</span>
          <button class="tui-btn" data-set-theme="solarized">Solarized Dark</button>
          <button class="tui-btn" data-set-theme="solarized-light">Solarized Light</button>
          <button class="tui-btn" data-set-theme="mocha">Mocha</button>
          <button class="tui-btn" data-set-theme="macchiato">Macchiato</button>
          <button class="tui-btn" data-set-theme="frappe">Frappe</button>
          <button class="tui-btn" data-set-theme="latte">Latte</button>
        </div>
        <div class="h-3 w-px bg-tui-bg-hl mx-1"></div>
        <div class="flex gap-2 items-center">
          <span class="opacity-50">FONT:</span>
          <button class="tui-btn" data-set-font="neon">Neon</button>
          <button class="tui-btn" data-set-font="argon">Argon</button>
          <button class="tui-btn" data-set-font="xenon">Xenon</button>
          <button class="tui-btn" data-set-font="radon">Radon</button>
          <button class="tui-btn" data-set-font="krypton">Krypton</button>
        </div>
      </div>
      <div class="text-tui-border-inactive">
        Lore <span class="text-tui-accent">0.24.4</span>
      </div>
    </footer>

    <script type="module">
      import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
      import svgPanZoom from 'https://cdn.jsdelivr.net/npm/svg-pan-zoom@3.6.1/+esm';

      // Theme logic
      const html = document.documentElement;
      const themeBtns = document.querySelectorAll('[data-set-theme]');
      const fontBtns = document.querySelectorAll('[data-set-font]');
      
      const savedTheme = localStorage.getItem('tui-theme') || 'solarized';
      setTheme(savedTheme);

      const savedFont = localStorage.getItem('tui-font') || 'neon';
      setFont(savedFont);

      themeBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const theme = btn.getAttribute('data-set-theme');
          setTheme(theme);
        });
      });

      fontBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const font = btn.getAttribute('data-set-font');
          setFont(font);
        });
      });

      function setTheme(theme) {
        html.setAttribute('data-theme', theme);
        localStorage.setItem('tui-theme', theme);
        themeBtns.forEach(b => {
          if (b.getAttribute('data-set-theme') === theme) {
            b.classList.add('active');
          } else {
            b.classList.remove('active');
          }
        });
      }

      function setFont(font) {
        html.setAttribute('data-font', font);
        localStorage.setItem('tui-font', font);
        fontBtns.forEach(b => {
          if (b.getAttribute('data-set-font') === font) {
            b.classList.add('active');
          } else {
            b.classList.remove('active');
          }
        });
      }

      // More robust conversion for syntax-highlighted blocks
      const convertMermaidBlocks = () => {
        const blocks = document.querySelectorAll('pre');
        let found = false;
        blocks.forEach(pre => {
          const text = pre.textContent.trim();
          // Match common mermaid starts like graph, flowchart, sequenceDiagram
          if (/^(graph|flowchart|sequenceDiagram|classDiagram|stateDiagram|erDiagram|journey|gantt|pie|quadrantChart|requirementDiagram)/i.test(text)) {
            const div = document.createElement('div');
            div.className = 'mermaid';
            // Unescape \n to actual newlines for Mermaid labels
            div.textContent = text.replace(/\\n/g, '\n');
            pre.replaceWith(div);
            found = true;
          }
        });
        return found;
      };

      // Get CSS variable value
      const getVar = (name) => getComputedStyle(document.documentElement).getPropertyValue(name).trim();

      const initMermaid = () => {
        mermaid.initialize({
          startOnLoad: false,
          theme: 'base',
          securityLevel: 'loose',
          flowchart: {
            htmlLabels: false,
            useMaxWidth: false,
            nodeSpacing: 60,
            rankSpacing: 60,
            curve: 'basis',
          },
          themeVariables: {
            background:       getVar('--tui-bg'),
            mainBkg:          getVar('--tui-bg-hl'),
            nodeBorder:       getVar('--tui-border-inactive'),
            lineColor:        getVar('--tui-fg'),
            textColor:        getVar('--tui-fg'),
            labelTextColor:   getVar('--tui-fg-em'),
            edgeLabelBackground: getVar('--tui-bg'),
            clusterBkg:       getVar('--tui-bg-hl'),
            clusterBorder:    getVar('--tui-border-inactive'),
            titleColor:       getVar('--tui-accent'),
            primaryColor:     getVar('--tui-bg-hl'),
            primaryBorderColor: getVar('--tui-border-active'),
            primaryTextColor: getVar('--tui-fg-em'),
            secondaryColor:   getVar('--tui-bg'),
            tertiaryColor:    getVar('--tui-bg-hl'),
            fontFamily:       getVar('--tui-font'),
            fontSize:         '13px',
          },
        });
      };

      if (convertMermaidBlocks()) {
        initMermaid();
        await mermaid.run();

        // Give the browser a moment to settle the SVG layout
        setTimeout(() => {
          document.querySelectorAll('.mermaid svg').forEach(svg => {
            svg.style.width = '100%';
            svg.style.height = '100%';
            svg.style.maxWidth = 'none';

            svgPanZoom(svg, {
              zoomEnabled: true,
              controlIconsEnabled: true,
              fit: true,
              center: true,
              minZoom: 0.1,
              maxZoom: 10,
              mouseWheelZoomEnabled: false,
            });
          });
        }, 100);
      }
    </script>
  </body>
</html>
