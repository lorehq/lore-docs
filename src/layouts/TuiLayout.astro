---
import '../styles/global.css';
import { isTabActive, sectionNav, sectionTitles, topTabs, type DocsSection } from '../lib/docs-nav';

interface Props {
  title: string;
  section?: DocsSection;
}

const { title, section = 'home' } = Astro.props;
const sidebarGroups = sectionNav[section];
---

<!doctype html>
<html lang="en" class="h-full w-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Lore</title>
    
    <!-- Universal Font: DejaVu Sans Mono -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/dejavu-sans-mono/index.css">

    <script is:inline>
      // Blocking script to prevent theme flashing
      (function() {
        const savedTheme = localStorage.getItem('tui-theme') || 'mocha';
        document.documentElement.setAttribute('data-theme', savedTheme);
      })();
    </script>
    <style is:global>
      .scrollbar-hide::-webkit-scrollbar { display: none; }
      .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }

      .tui-btn {
        padding-left: 0.5rem;
        padding-right: 0.5rem;
        cursor: pointer;
        font-size: 10px;
        background: transparent;
        color: inherit;
        opacity: 0.5;
        border: none;
        display: inline-flex;
        align-items: center;
        gap: 0.2rem;
      }
      .tui-btn:hover { opacity: 0.8; }
      .tui-btn.active {
        opacity: 1;
        color: var(--tui-fg-em);
        font-weight: bold;
      }
      .tui-btn.active::before { content: "["; color: var(--tui-accent); margin-right: 0.4rem; }
      .tui-btn.active::after { content: "]"; color: var(--tui-accent); margin-left: 0.4rem; }
      .tui-tab {
        opacity: 0.5;
        color: var(--tui-fg);
        text-decoration: none;
        padding: 0 0.5rem;
        transition: all 0.1s;
      }
      .tui-tab:hover { opacity: 0.8; }
      .tui-tab.active {
        opacity: 1;
        color: var(--tui-accent);
        font-weight: bold;
      }
      .tui-tab.active::before { content: "[ "; }
      .tui-tab.active::after { content: " ]"; }
    </style>
  </head>
  <body class="h-screen w-screen p-1 box-border flex flex-col gap-0 overflow-hidden bg-tui-bg text-tui-fg">
        <header class="h-5 flex items-center px-0 gap-2 text-xs">
      {topTabs.map(tab => (
        <a href={`/lore-docs${tab.href === '/' ? '/' : tab.href}`} class={`tui-tab ${isTabActive(section, tab.href) ? 'active' : ''}`}>{tab.label}</a>
      ))}
    </header>
    <div class="flex flex-1 gap-2 overflow-hidden">
      <!-- Navigation Panel -->
      <aside class="w-80 flex flex-col gap-2 mt-2">
        {sidebarGroups.map(group => (
          <div class="relative border border-tui-border-inactive p-2 pt-4 flex flex-col gap-1 w-full">
            <span class="absolute -top-2.5 left-2 bg-tui-bg px-1 text-[11px] font-bold text-tui-accent tracking-tighter">{group.label}</span>
            {group.items.map(item => (
              <a href={`/lore-docs${item.href === '/' ? '/' : item.href}`} class="py-0.5 px-2 hover:bg-tui-selected-bg hover:text-white block truncate transition-none">{item.label}</a>
            ))}
          </div>
        ))}
      </aside>

      <!-- Main Content -->
      <main class="relative border border-tui-border-active flex-1 flex flex-col mt-2">
        <span class="absolute -top-2.5 left-4 bg-tui-bg px-1 text-[10px] text-tui-border-active">{title || sectionTitles[section]}</span>

        <article class="flex-1 overflow-y-auto p-8 pt-10 prose text-tui-fg max-w-none scrollbar-hide">
          <slot />
        </article>
      </main>
    </div>

    <!-- Bottom Status Bar -->
    <footer class="h-6 flex items-center px-0 text-[10px] text-tui-border-inactive border-t border-tui-bg-hl justify-between">
      <div class="flex gap-4 items-center">
        
        
        <div class="flex gap-2 items-center">
          
          <button class="tui-btn" data-set-theme="mocha">Mocha</button>
          <button class="tui-btn" data-set-theme="macchiato">Macchiato</button>
          <button class="tui-btn" data-set-theme="frappe">Frappe</button>
          <button class="tui-btn" data-set-theme="latte">Latte</button>
          <button class="tui-btn" data-set-theme="solarized">Solarized Dark</button>
          <button class="tui-btn" data-set-theme="solarized-light">Solarized Light</button>
        </div>
      </div>
      <div class="text-tui-border-inactive">
        Lore <span class="text-tui-accent">0.24.5-BLUE</span>
      </div>
    </footer>

    <div class="image-lightbox" id="image-lightbox" aria-hidden="true">
      <div class="image-lightbox__frame">
        <button class="image-lightbox__close" id="image-lightbox-close" aria-label="Close image zoom">x</button>
        <img class="image-lightbox__img" id="image-lightbox-img" alt="" />
      </div>
    </div>

    <script is:inline>
      const html = document.documentElement;
      const themeBtns = document.querySelectorAll('[data-set-theme]');
      const lightbox = document.getElementById('image-lightbox');
      const lightboxImg = document.getElementById('image-lightbox-img');
      const lightboxClose = document.getElementById('image-lightbox-close');
      const article = document.querySelector('article');

      function updateActiveButton(theme) {
        themeBtns.forEach(btn => {
          if (btn.getAttribute('data-set-theme') === theme) btn.classList.add('active');
          else btn.classList.remove('active');
        });
      }

      themeBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const theme = btn.getAttribute('data-set-theme');
          html.setAttribute('data-theme', theme);
          localStorage.setItem('tui-theme', theme);
          updateActiveButton(theme);
          // Reload to refresh Shiki/Mermaid theme context
          window.location.reload();
        });
      });

      // Init UI state
      updateActiveButton(html.getAttribute('data-theme'));

      function closeLightbox() {
        lightbox.classList.remove('open');
        lightbox.setAttribute('aria-hidden', 'true');
        lightboxImg.removeAttribute('src');
        lightboxImg.alt = '';
      }

      article?.addEventListener('click', (event) => {
        const img = event.target.closest('img');
        if (!img) return;
        lightboxImg.setAttribute('src', img.getAttribute('src'));
        lightboxImg.alt = img.getAttribute('alt') || '';
        lightbox.classList.add('open');
        lightbox.setAttribute('aria-hidden', 'false');
      });

      article?.querySelectorAll('pre').forEach((pre) => {
        const code = pre.querySelector('code');
        if (!code) return;

        pre.classList.add('copy-ready');

        const button = document.createElement('button');
        button.className = 'code-copy-btn';
        button.type = 'button';
        button.textContent = 'Copy';
        button.setAttribute('aria-label', 'Copy code to clipboard');

        button.addEventListener('click', async () => {
          const text = code.innerText;
          try {
            await navigator.clipboard.writeText(text);
            button.textContent = 'Copied';
            button.classList.add('copied');
            window.setTimeout(() => {
              button.textContent = 'Copy';
              button.classList.remove('copied');
            }, 1600);
          } catch {
            button.textContent = 'Error';
            window.setTimeout(() => {
              button.textContent = 'Copy';
            }, 1600);
          }
        });

        pre.appendChild(button);
      });

      lightboxClose?.addEventListener('click', closeLightbox);
      lightbox?.addEventListener('click', (event) => {
        if (event.target === lightbox) closeLightbox();
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && lightbox.classList.contains('open')) closeLightbox();
      });
    </script>
  </body>
</html>
