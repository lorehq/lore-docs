---
import '../styles/global.css';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
}

const { title } = Astro.props;

const explanationRaw = await getCollection('explanation');
const referenceRaw = await getCollection('reference');

const explanationOrder = ['architecture', 'global-directory', 'agentic-system', 'memory', 'hooks', 'security', 'topology'];
const referenceOrder = ['databank', 'configuration', 'hooks', 'commands'];

const sortByOrder = (entries: typeof explanationRaw, order: string[]) => {
  return [...entries].sort((a, b) => {
    const ai = order.indexOf(a.id);
    const bi = order.indexOf(b.id);
    return (ai === -1 ? 999 : ai) - (bi === -1 ? 999 : bi);
  });
};

const explanation = sortByOrder(explanationRaw.filter(e => !e.id.includes('/')), explanationOrder);
const topReference = sortByOrder(referenceRaw.filter(e => !e.id.includes('/')), referenceOrder);
---

<!doctype html>
<html lang="en" class="h-full w-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Lore</title>
    
    <!-- Universal Font: DejaVu Sans Mono -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/dejavu-sans-mono/index.css">

    <script is:inline>
      // Blocking script to prevent theme flashing
      (function() {
        const savedTheme = localStorage.getItem('tui-theme') || 'solarized';
        document.documentElement.setAttribute('data-theme', savedTheme);
      })();
    </script>
    <style is:global>
      .scrollbar-hide::-webkit-scrollbar { display: none; }
      .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }

      .tui-btn {
        padding-left: 0.25rem;
        padding-right: 0.25rem;
        border: 1px solid transparent;
        cursor: pointer;
        transition: all 0.1s;
        font-size: 10px;
        background: transparent;
        color: inherit;
        opacity: 0.6;
      }
      .tui-btn:hover { opacity: 1; color: var(--tui-accent); }
      .tui-btn.active {
        opacity: 1;
        color: var(--tui-accent);
        border-color: var(--tui-accent);
        background-color: var(--tui-bg-hl);
      }
    </style>
  </head>
  <body class="h-screen w-screen p-2 box-border flex flex-col gap-2 overflow-hidden bg-tui-bg text-tui-fg select-none">
    <div class="flex flex-1 gap-2 overflow-hidden">
      <!-- Navigation Panel -->
      <aside class="relative border border-tui-border-inactive w-80 flex flex-col mt-3">
        <span class="absolute -top-2.5 left-2 bg-tui-bg px-1 text-[10px] text-tui-border-inactive">[1]-Navigation</span>

        <nav class="flex-1 overflow-y-auto p-2 pt-4 flex flex-col gap-4 scrollbar-hide text-xs">
          <div>
            <a href="/lore/" class="py-0.5 px-2 hover:bg-tui-selected-bg hover:text-white block transition-none">Home</a>
          </div>

          <div>
            <div class="opacity-70 text-[11px] px-2 uppercase mb-1 font-bold text-tui-accent">Architecture</div>
            {explanation.map(entry => (
              <a href={`/lore/explanation/${entry.id}`} class="py-0.5 px-2 hover:bg-tui-selected-bg hover:text-white block truncate transition-none">{entry.data.title}</a>
            ))}
          </div>

          <div class="mb-4">
            <div class="opacity-70 text-[11px] px-2 uppercase mb-1 font-bold text-tui-accent">Reference</div>
            {topReference.map(entry => (
              <a href={`/lore/reference/${entry.id}`} class="py-0.5 px-2 hover:bg-tui-selected-bg hover:text-white block truncate transition-none">{entry.data.title}</a>
            ))}
          </div>
        </nav>
      </aside>

      <!-- Main Content -->
      <main class="relative border border-tui-border-active flex-1 flex flex-col mt-3">
        <span class="absolute -top-2.5 left-4 bg-tui-bg px-1 text-[10px] text-tui-border-active">[2]-{title}</span>

        <article class="flex-1 overflow-y-auto p-8 pt-10 prose text-tui-fg max-w-none scrollbar-hide">
          <slot />
        </article>
      </main>
    </div>

    <!-- Bottom Status Bar -->
    <footer class="h-6 flex items-center px-2 text-[10px] text-tui-border-inactive border-t border-tui-bg-hl justify-between">
      <div class="flex gap-4 items-center">
        <span>PgUp/PgDn: scroll</span>
        <div class="h-3 w-px bg-tui-bg-hl mx-1"></div>
        <div class="flex gap-2 items-center">
          <span class="opacity-50">THEME:</span>
          <button class="tui-btn" data-set-theme="solarized">Solarized Dark</button>
          <button class="tui-btn" data-set-theme="solarized-light">Solarized Light</button>
          <button class="tui-btn" data-set-theme="mocha">Mocha</button>
          <button class="tui-btn" data-set-theme="macchiato">Macchiato</button>
          <button class="tui-btn" data-set-theme="frappe">Frappe</button>
          <button class="tui-btn" data-set-theme="latte">Latte</button>
        </div>
      </div>
      <div class="text-tui-border-inactive">
        Lore <span class="text-tui-accent">0.24.5-BLUE</span>
      </div>
    </footer>

    <script is:inline>
      const html = document.documentElement;
      const themeBtns = document.querySelectorAll('[data-set-theme]');

      function updateActiveButton(theme) {
        themeBtns.forEach(btn => {
          if (btn.getAttribute('data-set-theme') === theme) btn.classList.add('active');
          else btn.classList.remove('active');
        });
      }

      themeBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const theme = btn.getAttribute('data-set-theme');
          html.setAttribute('data-theme', theme);
          localStorage.setItem('tui-theme', theme);
          updateActiveButton(theme);
          // Reload to refresh Shiki/Mermaid theme context
          window.location.reload();
        });
      });

      // Init UI state
      updateActiveButton(html.getAttribute('data-theme'));
    </script>
  </body>
</html>
